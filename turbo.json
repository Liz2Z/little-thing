{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"],
      "cache": true,
      "inputs": ["src/**/*.ts", "__tests__/**/*.ts", "package.json"]
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "outputs": ["coverage/**"],
      "cache": true,
      "inputs": ["src/**/*.ts", "__tests__/**/*.ts", "package.json"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:ci": {
      "dependsOn": ["^test:ci"],
      "outputs": ["coverage/**"],
      "cache": false,
      "inputs": ["src/**/*.ts", "__tests__/**/*.ts", "package.json"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    }
  }
}
