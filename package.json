{
  "name": "little-thing",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "bun run --filter @littlething/server --stream --elide-lines=0 dev",
    "dev:cli": "bun run --filter @littlething/cli dev",
    "dev:web": "bun run --filter @littlething/web dev",
    "dev": "bun run dev:server & bun run dev:web",
    "generate:sdk": "cd packages/sdk && bun run generate",
    "build": "bun run --filter '*' build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "turbo run test:watch",
    "test:ci": "turbo run test:ci",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "c8": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.8.20",
    "typescript": "^5"
  },
  "dependencies": {
  }
}
