{
  "name": "little-thing",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "c8": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "dev:thing": "bun run --filter @littlething/thing dev",
    "dev:web": "bun run --filter @littlething/web dev",
    "dev": "bun run dev:thing",
    "generate:sdk": "cd packages/sdk && bun run generate",
    "build": "bun run --filter '*' build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "turbo run test:watch",
    "test:ci": "turbo run test:ci",
    "test:e2e:server": "NODE_ENV=test bun test e2e/server",
    "test:e2e:web": "playwright test e2e/web",
    "test:e2e": "bun run test:e2e:server && bun run test:e2e:web",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*"
  ]
}
